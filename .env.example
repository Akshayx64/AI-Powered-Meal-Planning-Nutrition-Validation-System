# LLM API Keys
GEMINI_API_KEY=your_gemini_api_key_here

# Default LLM to use
# Options: gemini/gemini-2.0-flash-lite, gemini/gemini-2.0-flash-exp, groq/llama3-70b-8192, groq/llama-3.3-70b-versatile
DEFAULT_LLM=gemini/gemini-2.0-flash-lite

# USDA FoodData Central API
USDA_API_KEY=your_usda_api_key_here
FDC_API_KEY=your_usda_api_key_here

# API Ninjas Key (optional)
API_NINJAS_KEY=your_api_ninjas_key_here

# External Service Keys
SERPER_API_KEY=your_serper_api_key_here

# Agent Configuration
MAX_ITERATIONS=10
VERBOSE_MODE=true

# Rate Limiting
MAX_RPM=5
REQUEST_DELAY=12

# A2A Configuration
ADK_AGENT_PORT=8080
ADK_AGENT_HOST=localhost

# MCP Server Configuration
MCP_NUTRITION_SERVER_PATH=mcp-nutrition-tools/src/mcp_server.py

# Web Search MCP Configuration
WEB_SEARCH_ENGINE=duckduckgo
ALLOWED_SEARCH_ENGINES=duckduckgo,bing,brave

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/agent_execution.log
CREWAI_TRACING_ENABLED=true
